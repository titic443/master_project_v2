{
  "source": {
    "file": "lib/demos/clinic_appointment_page.dart",
    "pageClass": "ClinicAppointmentPage",
    "cubitClass": "ClinicAppointmentCubit",
    "stateClass": "ClinicAppointmentState",
    "fileCubit": "lib/cubit/clinic_appointment_cubit.dart",
    "fileState": "lib/cubit/clinic_appointment_state.dart"
  },
  "widgets": [
    {
      "widgetType": "SnackBar",
      "key": "appt_10_expected_fail"
    },
    {
      "widgetType": "SnackBar",
      "key": "appt_10_expected_success"
    },
    {
      "widgetType": "TextFormField",
      "key": "appt_01_patient_name_textfield",
      "meta": {
        "validatorRules": [
          {
            "condition": "v == null || v.trim().isEmpty",
            "message": "กรุณากรอกชื่อ-นามสกุล"
          },
          {
            "condition": "v.trim().length < 2",
            "message": "อย่างน้อย 2 ตัวอักษร"
          }
        ]
      }
    },
    {
      "widgetType": "TextFormField",
      "key": "appt_02_id_card_textfield",
      "meta": {
        "keyboardType": "number",
        "inputFormatters": [
          {
            "type": "digitsOnly"
          },
          {
            "type": "lengthLimit",
            "max": 13
          }
        ],
        "validatorRules": [
          {
            "condition": "v == null || v.trim().isEmpty",
            "message": "กรุณากรอกเลขบัตรประชาชน"
          },
          {
            "condition": "v.trim().length != 13",
            "message": "ต้องมี 13 หลัก"
          }
        ]
      }
    },
    {
      "widgetType": "TextFormField",
      "key": "appt_03_phone_textfield",
      "meta": {
        "keyboardType": "phone",
        "inputFormatters": [
          {
            "type": "digitsOnly"
          },
          {
            "type": "lengthLimit",
            "max": 10
          }
        ],
        "validatorRules": [
          {
            "condition": "v == null || v.trim().isEmpty",
            "message": "กรุณากรอกเบอร์โทรศัพท์"
          },
          {
            "condition": "v.trim().length < 9",
            "message": "เบอร์โทรไม่ถูกต้อง"
          }
        ]
      }
    },
    {
      "widgetType": "DropdownButtonFormField<String>",
      "key": "appt_04_department_dropdown",
      "meta": {
        "options": [
          {
            "value": "internal_medicine",
            "text": "อายุรกรรม"
          },
          {
            "value": "surgery",
            "text": "ศัลยกรรม"
          },
          {
            "value": "pediatrics",
            "text": "กุมารเวชศาสตร์"
          },
          {
            "value": "obstetrics",
            "text": "สูติ-นรีเวช"
          },
          {
            "value": "ophthalmology",
            "text": "จักษุวิทยา"
          },
          {
            "value": "ent",
            "text": "หู คอ จมูก"
          },
          {
            "value": "orthopedics",
            "text": "กระดูกและข้อ"
          }
        ]
      }
    },
    {
      "widgetType": "Radio<String>",
      "key": "appt_05_type_radio_opd",
      "meta": {
        "valueExpr": "'OPD'",
        "groupValueBinding": "state.appointmentType"
      }
    },
    {
      "widgetType": "Radio<String>",
      "key": "appt_05_type_radio_tele",
      "meta": {
        "valueExpr": "'Telemedicine'",
        "groupValueBinding": "state.appointmentType"
      }
    },
    {
      "widgetType": "TextFormField",
      "key": "appt_06_date_textfield",
      "meta": {
        "validatorRules": [
          {
            "condition": "v == null || v.trim().isEmpty",
            "message": "กรุณาเลือกวันที่นัดหมาย"
          }
        ]
      },
      "onTap": "_selectDate",
      "pickerMetadata": {
        "type": "DatePicker",
        "firstDate": "DateTime(2000)",
        "lastDate": "DateTime(2031)",
        "initialDate": "now.add(const Duration(days: 1))"
      }
    },
    {
      "widgetType": "TextFormField",
      "key": "appt_07_time_textfield",
      "meta": {
        "validatorRules": [
          {
            "condition": "v == null || v.trim().isEmpty",
            "message": "กรุณาเลือกช่วงเวลา"
          }
        ]
      },
      "onTap": "_selectTime",
      "pickerMetadata": {
        "type": "TimePicker",
        "initialTime": "const TimeOfDay(hour: 9, minute: 0)"
      }
    },
    {
      "widgetType": "Switch",
      "key": "appt_08_insurance_switch",
      "meta": {
        "valueBinding": "state.hasInsurance"
      }
    },
    {
      "widgetType": "TextFormField",
      "key": "appt_09_note_textfield"
    },
    {
      "widgetType": "ElevatedButton",
      "key": "appt_10_confirm_button"
    }
  ]
}
